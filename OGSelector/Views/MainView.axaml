<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:OGSelector.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="OGSelector.Views.MainView"
             x:DataType="vm:MainViewModel"
             xmlns:progRing="clr-namespace:AvaloniaProgressRing;assembly=AvaloniaProgressRing"
             xmlns:lottie="clr-namespace:Avalonia.Labs.Lottie;assembly=Avalonia.Labs.Lottie"
             >
    <Design.DataContext>
      <!-- This only sets the DataContext for the previewer in an IDE,
           to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
      <vm:MainViewModel />
    </Design.DataContext>
	
    <UserControl.Styles>
            <!-- Make TextBlocks with the h1 style class have a font size of 24 points -->
            <Style Selector="TextBlock.h1">
                <Setter Property="FontSize" Value="34"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Medium"/>
            </Style>
            <Style Selector="TextBlock.h2">
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Medium"/>
            </Style>
            <Style Selector="TextBlock.h3">
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Medium"/>
            </Style>
            <Style Selector="TextBlock.h4">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Normal"/>
            </Style>
            <Style Selector="TextBlock.e1">
                <Setter Property="FontSize" Value="30"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="#d70000"/>
            </Style>
            <Style Selector="TextBlock.p1">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Normal"/>
            </Style>
            <Style Selector="TextBlock.p2">
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Normal"/>
            </Style>
            <Style Selector="Label.p1">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>
            <Style Selector="Label.p2">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Normal"/>
            </Style>
            <Style Selector="Button">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Background" Value="#0078d7" />
                <Setter Property="Foreground" Value="AntiqueWhite" />
            </Style>
            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#0063b1" />
                <Setter Property="Foreground" Value="#e3e3e3" />
            </Style>
    </UserControl.Styles>
	
    <Panel>
        <ExperimentalAcrylicBorder CornerRadius="8">
            <ExperimentalAcrylicBorder.Material >
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="White"
                    TintOpacity="1"
                    MaterialOpacity="0.3"
					/>
            </ExperimentalAcrylicBorder.Material>

            <Border CornerRadius="8" Background="White" Width="1200" Height="800">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="600"></ColumnDefinition>
                        <ColumnDefinition Width="600"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100"></RowDefinition>
                        <RowDefinition Height="600"></RowDefinition>
                        <RowDefinition Height="100"></RowDefinition>
                    </Grid.RowDefinitions>

                    <StackPanel Name="CompanyLogoPanel" VerticalAlignment="Center" HorizontalAlignment="Left" Background="Transparent" Grid.Row="0" Grid.Column="0" Margin="0,0,0,0" Width="500" Panel.ZIndex="0" IsHitTestVisible="False">
                        <Image Name="CompanyLogo" Margin="20,20,0,0" Width="200"/>
                    </StackPanel>
                    <StackPanel Name="Pretty" VerticalAlignment="Center" HorizontalAlignment="Left" Background="Transparent" Grid.Row="1" Grid.Column="0" Width="500" Margin="0,0,0,0" Panel.ZIndex="0" IsHitTestVisible="False">
                        <Lottie Path="/Assets/glass.json"/>
                    </StackPanel>
                    <StackPanel Name="Footer" VerticalAlignment="Bottom" HorizontalAlignment="Center" Background="Transparent" Grid.Row="2" Grid.ColumnSpan="2" Width="1200" Margin="0,0,0,0" Panel.ZIndex="0" IsHitTestVisible="False">
                        <Lottie Path="/Assets/footer.json" Width="1200" Margin="0,0,0,-100"/>
                    </StackPanel>
                    <StackPanel Name="MainPanel" IsVisible="{Binding !HasError}" VerticalAlignment="Center" Background="Transparent" Grid.Row="1" Grid.Column="1" Margin="50,-50,0,0" Height="400" Panel.ZIndex="1" IsHitTestVisible="True">
                        <TextBlock Name="Headline" Classes="h1" HorizontalAlignment="Left"></TextBlock>
                        <TextBlock Name="Subtitle" Classes="h2" HorizontalAlignment="Left" Opacity="0.6" Margin="0,0,0,0" TextWrapping="Wrap"></TextBlock>
                        <WrapPanel HorizontalAlignment ="Left" Width="400" Margin="0,20,0,0">
                        <TextBlock Name="Information" Classes="p1" TextWrapping="Wrap"></TextBlock>
                        </WrapPanel>
                        
                        <!-- Selection ComboBoxes -->
                        <StackPanel HorizontalAlignment="Left" Margin="0,20,0,0" Width="400">
                            <Label Classes="p1" Margin="0,10,0,5">Business Unit:</Label>
                            <ComboBox Name="BUComboBox" 
                                    ItemsSource="{Binding BusinessUnits}" 
                                    SelectedItem="{Binding SelectedBusinessUnit}"
                                    Width="400"
                                    HorizontalAlignment="Left"
                                    MaxDropDownHeight="300">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <StackPanel IsVisible="{Binding HasProcess}">
                                <Label Classes="p1" Margin="0,15,0,5">Process:</Label>
                                <ComboBox Name="ProcessComboBox" 
                                        ItemsSource="{Binding Processes}" 
                                        SelectedItem="{Binding SelectedProcess}"
                                        Width="400"
                                        HorizontalAlignment="Left"
                                        MaxDropDownHeight="300">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel IsVisible="{Binding HasRoles}">
                                <Label Classes="p1" Margin="0,15,0,5">Role:</Label>
                                <ComboBox Name="RoleComboBox" 
                                        ItemsSource="{Binding Roles}" 
                                        SelectedItem="{Binding SelectedRole}"
                                        Width="400"
                                        HorizontalAlignment="Left"
                                        MaxDropDownHeight="300">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel IsVisible="{Binding HasGeos}">
                                <Label Classes="p1" Margin="0,15,0,5">Geo:</Label>
                                <ComboBox Name="GeoComboBox" 
                                        ItemsSource="{Binding Geos}" 
                                        SelectedItem="{Binding SelectedGeo}"
                                        Width="400"
                                        HorizontalAlignment="Left"
                                        MaxDropDownHeight="300">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            
                            <Button Name="SubmitButton" 
                                    Command="{Binding SubmitCommand}"
                                    Margin="0,30,0,0" 
                                    Width="150"
                                    Height="40"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center">Submit</Button>
                            
                            <TextBlock Text="{Binding StatusMessage}" 
                                    Classes="e1" 
                                    Margin="0,15,0,0"
                                    HorizontalAlignment="Center"
                                    TextWrapping="Wrap"/>
                        </StackPanel>
                        
                    </StackPanel>
                    <StackPanel Name="ErrorPanel" IsVisible="{Binding HasError}" Background="Transparent" Grid.Row="1" Grid.Column="1" Margin="0,0,0,0" Height="400" Panel.ZIndex="1" IsHitTestVisible="True">
                        <TextBlock Name="ErrorHeadline" Classes="h1" HorizontalAlignment="Left"></TextBlock>
                        <!-- <TextBlock Name="ErrorSubtitle" Classes="h2" HorizontalAlignment="Left" Opacity="0.6" Margin="0,0,0,0"></TextBlock> -->
                        <WrapPanel Name="ErrorInformation" HorizontalAlignment ="Left" Margin="0,20,0,0">
                            <TextBlock Classes="e1" TextWrapping="Wrap"></TextBlock>
                        </WrapPanel>
                        <Button Name="CloseButton"
                                Command="{Binding CloseAppCommand}"
                                Margin="0,30,0,0" 
                                Width="150"
                                Height="40"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center">Close</Button>
                        
                        <!-- <Lottie Path="/Assets/stick.json" VerticalAlignment="Center" HorizontalAlignment="Center" Width="300" RepeatCount="1" Margin="0,30,0,0"/> -->
                    </StackPanel>
                </Grid>
            </StackPanel>
            </Border>
            
		</ExperimentalAcrylicBorder>
	</Panel>
</UserControl>
