<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="OGSelector.MainPage"
    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F1F1F}"
    Padding="20">

    <ScrollView>
        <VerticalStackLayout Spacing="20">
            <!-- Title -->
            <Label
                Text="OG Selector"
                Style="{StaticResource HeadingStyle}"
                HorizontalTextAlignment="Center"
                Margin="0,10" />

            <!-- Status Message -->
            <Label
                Text="{Binding StatusMessage}"
                Style="{StaticResource LabelStyle}"
                HorizontalTextAlignment="Center"
                FontSize="12"
                TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

            <!-- URL Input Section -->
            <VerticalStackLayout Spacing="10">
                <Label
                    Text="JSON URL:"
                    Style="{StaticResource LabelStyle}"
                    FontAttributes="Bold" />
                <Entry
                    x:Name="UrlEntry"
                    Text="{Binding JsonUrl}"
                    Placeholder="Enter JSON URL"
                    PlaceholderColor="{AppThemeBinding Light=#CCCCCC, Dark=#666666}"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#333333}"
                    Padding="10"
                    CornerRadius="5" />
                <Button
                    Text="Load Data"
                    Command="{Binding LoadDataCommand}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="5"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />
            </VerticalStackLayout>

            <!-- Loading Indicator -->
            <ActivityIndicator
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="#512BD4" />

            <!-- Separator -->
            <BoxView
                Color="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"
                HeightRequest="1"
                Margin="0,10" />

            <!-- Business Units Dropdown -->
            <VerticalStackLayout Spacing="8">
                <Label
                    Text="Business Unit:"
                    Style="{StaticResource LabelStyle}"
                    FontAttributes="Bold" />
                <Picker
                    Title="Select a Business Unit"
                    ItemsSource="{Binding BusinessUnits}"
                    SelectedItem="{Binding SelectedBusinessUnit}"
                    ItemDisplayBinding="{Binding Display}"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#333333}"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
            </VerticalStackLayout>

            <!-- Roles Dropdown -->
            <VerticalStackLayout Spacing="8">
                <Label
                    Text="Role:"
                    Style="{StaticResource LabelStyle}"
                    FontAttributes="Bold" />
                <Picker
                    Title="Select a Role"
                    ItemsSource="{Binding Roles}"
                    SelectedItem="{Binding SelectedRole}"
                    ItemDisplayBinding="{Binding Display}"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#333333}"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
            </VerticalStackLayout>

            <!-- Geos Dropdown -->
            <VerticalStackLayout Spacing="8">
                <Label
                    Text="Geography:"
                    Style="{StaticResource LabelStyle}"
                    FontAttributes="Bold" />
                <Picker
                    Title="Select a Geography"
                    ItemsSource="{Binding Geos}"
                    SelectedItem="{Binding SelectedGeo}"
                    ItemDisplayBinding="{Binding Display}"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#333333}"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
            </VerticalStackLayout>

            <!-- Selection Summary -->
            <VerticalStackLayout
                Spacing="10"
                Padding="15"
                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#2A2A2A}"
                CornerRadius="5">
                <Label
                    Text="Current Selections:"
                    Style="{StaticResource LabelStyle}"
                    FontAttributes="Bold" />
                <HorizontalStackLayout Spacing="5">
                    <Label
                        Text="BU:"
                        Style="{StaticResource LabelStyle}"
                        FontAttributes="Bold" />
                    <Label
                        Text="{Binding SelectedBusinessUnit.Display, StringFormat='{0}'}"
                        Style="{StaticResource LabelStyle}" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="5">
                    <Label
                        Text="Role:"
                        Style="{StaticResource LabelStyle}"
                        FontAttributes="Bold" />
                    <Label
                        Text="{Binding SelectedRole.Display, StringFormat='{0}'}"
                        Style="{StaticResource LabelStyle}" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="5">
                    <Label
                        Text="Geo:"
                        Style="{StaticResource LabelStyle}"
                        FontAttributes="Bold" />
                    <Label
                        Text="{Binding SelectedGeo.Display, StringFormat='{0}'}"
                        Style="{StaticResource LabelStyle}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Submit Button -->
            <Button
                Text="Submit"
                Command="{Binding SubmitCommand}"
                BackgroundColor="#28A745"
                TextColor="White"
                FontAttributes="Bold"
                Padding="20,15"
                CornerRadius="5"
                Margin="0,10" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
